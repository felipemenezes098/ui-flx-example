# Next.js Environment Variables
# Copy this file to .env.local and fill in your values

# Your Sanity project ID
# Must match the project ID used in your Sanity Studio
# Find it in your Sanity project settings: https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id

# Your Sanity dataset name (usually 'production' or 'development')
# Must match the dataset used in your Sanity Studio
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API version
# Use a date string in YYYY-MM-DD format
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Optional: Sanity API read token for authenticated requests
# Only needed if you're using preview mode or need authenticated access
# Generate it in your Sanity project settings: https://www.sanity.io/manage
# SANITY_API_READ_TOKEN=your-read-token