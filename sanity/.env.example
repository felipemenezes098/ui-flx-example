th3_Z4xUClE1c8# Sanity Studio Environment Variables
# Copy this file to .env.local and fill in your values

# Your Sanity project ID
# Find it in your Sanity project settings
SANITY_STUDIO_PROJECT_ID=your-project-id

# Your Sanity dataset name (usually 'production' or 'development')
SANITY_STUDIO_DATASET=production